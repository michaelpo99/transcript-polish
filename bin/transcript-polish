#!/usr/bin/env python3
from pathlib import Path
import sys

# 這支檔案是 repo 內的開發入口。
# 正式部署時，應優先使用 `pip install .` 產生的 transcript-polish 指令。
#
# 主要處理流程位於 src/transcript_polish/cli.py；entrypoint.py 另外負責
# standard / quality 模式與使用者設定檔解析。
REPO_ROOT = Path(__file__).resolve().parents[1]
SRC_ROOT = REPO_ROOT / "src"

if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from transcript_polish.entrypoint import main


if __name__ == "__main__":
    sys.exit(main())
